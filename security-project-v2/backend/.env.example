# ============================================================
# SecLab — Variables d'environnement
# Copiez ce fichier en .env et modifiez les valeurs
# NE JAMAIS committer le .env réel dans git
# ============================================================

# ─── Base de données MySQL ───────────────────────────────────
MYSQL_ROOT_PASSWORD=SecureRoot@2024!
MYSQL_DATABASE=security_lab
MYSQL_USER=seclab_user
MYSQL_PASSWORD=SecureDB@2024!
# Hôte MySQL (nom du service Docker Compose)
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ─── Sécurité JWT ───────────────────────────────────────────
# IMPORTANT : Changez ces valeurs en production !
# Générez avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=superSecretJWTKey2024ForSecurityLabGraduationProject!
JWT_REFRESH_SECRET=superSecretRefreshKey2024ForSecurityLabGraduationProject!

# ─── Application ────────────────────────────────────────────
NODE_ENV=development
# development | production | test
PORT=3001

# ─── CORS ───────────────────────────────────────────────────
# En développement : http://localhost ou http://localhost:5173
# En production : https://votre-domaine.com
CORS_ORIGIN=http://localhost

# ─── Logging ────────────────────────────────────────────────
# Niveau de log Morgan : dev | combined | common | tiny
LOG_LEVEL=dev

# ─── Rate Limiting ──────────────────────────────────────────
# Ces valeurs sont en milliseconds
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100            # Requêtes max par fenêtre
AUTH_LIMIT_MAX=10             # Tentatives auth max

# ─── Sécurité avancée ───────────────────────────────────────
# Durée d'expiration du token d'accès
JWT_EXPIRES_IN=24h
# Durée d'expiration du refresh token
JWT_REFRESH_EXPIRES_IN=7d
# Rounds bcrypt (10 = ~100ms, 12 = ~400ms recommandé en prod)
BCRYPT_ROUNDS=12
